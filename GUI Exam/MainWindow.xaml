<Window x:Class="GUI_Exam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI_Exam"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="300"
    
        Background="#8C8DDE">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="49*"/>
            <RowDefinition Height="197*"/>
            <RowDefinition Height="94*"/>
            <RowDefinition Height="94*"/>
        </Grid.RowDefinitions>
        <Button Name = "ODP_1" Content="A" Grid.Row="2" Click="Button_A_Click" Margin="5,5,5,5" FontSize="32"/>
        <Button Name = "ODP_2" Content="B" Grid.Row="3" Click="Button_B_Click" Margin="5,5,5,5" FontSize="32"/>
        <Button Name = "ODP_3" Content="C" Click="Button_C_Click" Grid.Column="1" Grid.Row="2" Margin="5,5,5,5" FontSize="32"/>
        <Button Name = "ODP_4" Content="D" Grid.Row="3" Click="Button_D_Click" Grid.Column="1" Margin="5,5,5,5" FontSize="32"/>
        <Border Grid.ColumnSpan="2" CornerRadius="20" Background="White" Padding="30" VerticalAlignment="Top" HorizontalAlignment="Center" BorderBrush="Black" BorderThickness="2" Grid.Row="1" >
            <TextBlock Name = "Pytanie"  FontSize="25" HorizontalAlignment="Center" TextWrapping="Wrap" Text="Pytanie" VerticalAlignment="Top" TextAlignment="Center" Foreground="Black"/>
        </Border>
        <TextBlock Name = "Wynik" FontSize="25" HorizontalAlignment="Center"  TextWrapping="Wrap" Text="" VerticalAlignment="Bottom" Grid.ColumnSpan="2" Grid.Row="1"/>
        <TextBlock Name = "Licznik" TextAlignment="Center" Foreground="White" TextWrapping="Wrap" Text="0"  FontSize="40" Grid.ColumnSpan="2" VerticalAlignment="Top" HorizontalAlignment="Center"/>
    </Grid>
</Window>
